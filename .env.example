# ===== 必填配置 =====
# 大模型 API Key（默认使用阿里云通义千问，前往 https://bailian.console.aliyun.com 获取）
API_KEY=your_api_key_here

# 闲鱼网页版 Cookie（F12 → Network → 任意请求 → 复制 Cookie 字段）
COOKIES_STR=your_cookies_here

# ===== 模型配置 =====
# --- 选项A：阿里云通义千问（默认，国内访问快，支持联网搜索）---
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-max

# --- 选项B：OpenAI（需要单独注册 platform.openai.com 并充值获取 API Key）---
# 注意：ChatGPT Plus 订阅（$20/月）≠ API 权限，两者独立计费
# MODEL_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o
# 推荐模型：gpt-4o（最强）、gpt-4o-mini（便宜10倍，客服场景够用）

# --- 选项C：DeepSeek（国产，价格极低，效果接近GPT-4）---
# MODEL_BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat

# --- 选项D：本地模型（通过 Ollama 部署）---
# MODEL_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=qwen2.5:7b

# ===== 多账号标识（新增） =====
# 用于在飞书通知中区分是哪个闲鱼账号收到消息
# 每个账号的项目文件夹改成不同的名称，如：账号A、账号B、主号等
ACCOUNT_NAME=我的闲鱼账号

# ===== 飞书通知（两种方式二选一，都不填则不发通知） =====

# --- 方式一：应用机器人私信（推荐，可直接发到你个人，无需群）---
# 步骤：
#   1. 打开 https://open.feishu.cn/app → 创建企业自建应用
#   2. 应用凭证页面获取 App ID 和 App Secret
#   3. 权限管理 → 开通 "发送消息" 权限（im:message:send_as_bot）
#   4. 发布应用（测试版也可）
#   5. 获取你自己的 User ID：
#      飞书 PC 端 → 点击头像 → 个人设置 → 账号安全 → 复制 "User ID"
#      （也可以在 https://open.feishu.cn/api-explorer 中用接口查询）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ID=        # 你的飞书 User ID，格式如 ou_xxxxxxxx 或纯数字

# --- 方式二：自定义机器人群消息（只能发到群，配置更简单）---
# 获取方式：飞书群 → 设置 → 机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook
# 注意：若同时配置了方式一，方式一优先，方式二不生效
FEISHU_WEBHOOK_URL=

# ===== 运行行为配置 =====
# 人工接管切换关键词（默认中文句号，在闲鱼聊天框输入句号切换为人工/AI）
TOGGLE_KEYWORDS=。

# 模拟人工输入延迟（True=开启，False=关闭）
SIMULATE_HUMAN_TYPING=False

# 人工接管自动超时时间（秒，默认3600=1小时后自动切回AI）
MANUAL_MODE_TIMEOUT=3600

# 消息过期时间（毫秒，默认300000=5分钟，超过此时间的历史消息不处理）
MESSAGE_EXPIRE_TIME=300000

# ===== 连接配置（一般无需修改） =====
HEARTBEAT_INTERVAL=15
HEARTBEAT_TIMEOUT=5
TOKEN_REFRESH_INTERVAL=3600
TOKEN_RETRY_INTERVAL=300

# ===== 日志级别 =====
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
